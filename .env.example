# Configuración del Kernel Renders Agent
#
# La forma recomendada de configurar es ejecutar:
#   kernel-agent setup
#
# El wizard interactivo te pide los valores y los guarda en:
#   Windows:  C:\Users\<usuario>\AppData\Local\KernelRendersAgent\config.json
#   Mac:      ~/Library/Application Support/KernelRendersAgent/config.json
#   Linux:    ~/.config/KernelRendersAgent/config.json
#
# Pero también puedes pegar estos valores en .env (mismo folder) si prefieres:

# URL del servidor (Vercel)
KERNEL_RENDERS_SERVER_URL=https://kernel-renders-web.vercel.app

# Token único del agent (cópialo de la UI: /settings/agents)
KERNEL_RENDERS_API_KEY=kr_agent_...

# Path absoluto a blender.exe (autodetectable)
BLENDER_BIN=C:\Program Files\Blender Foundation\Blender 5.1\blender.exe

# Carpetas
LIBRARY_DIR=C:\Users\<usuario>\kernel-renders\recursos
OUTPUT_DIR=C:\Users\<usuario>\Downloads\kernel-renders

# Polling
POLL_INTERVAL_SECONDS=5

# Identificador humano del agent (lo que aparece en /settings/agents)
AGENT_NAME=Mi PC
